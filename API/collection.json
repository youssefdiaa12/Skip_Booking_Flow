{
  "info": {
    "name": "Skip Booking System API",
    "description": "API collection for QA Assessment - Skip Booking System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Postcode Lookup",
      "item": [
        {
          "name": "SW1A 1AA - Returns 12 addresses",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/postcode/lookup",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postcode\": \"SW1A 1AA\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function() {",
                  "  pm.expect(pm.response.status).toBe(200);",
                  "});",
                  "pm.test(\"Returns 12 addresses\", function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.addresses.length).toBe(12);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "EC1A 1BB - Returns 0 addresses (empty)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/postcode/lookup",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postcode\": \"EC1A 1BB\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function() {",
                  "  pm.expect(pm.response.status).toBe(200);",
                  "});",
                  "pm.test(\"Returns empty array\", function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.addresses.length).toBe(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "M1 1AE - Simulated latency",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/postcode/lookup",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postcode\": \"M1 1AE\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function() {",
                  "  pm.expect(pm.response.status).toBe(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "BS1 4DJ - First call returns 500 error",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/postcode/lookup",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postcode\": \"BS1 4DJ\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 500\", function() {",
                  "  pm.expect(pm.response.status).toBe(500);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Waste Types",
      "item": [
        {
          "name": "Submit waste type",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/waste-types",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"heavyWaste\": false,\n  \"plasterboard\": true,\n  \"plasterboardOption\": \"separate\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function() {",
                  "  pm.expect(pm.response.status).toBe(200);",
                  "});",
                  "pm.test(\"Returns ok true\", function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.ok).toBe(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Skips",
      "item": [
        {
          "name": "Get skips - General waste",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/skips?postcode=SW1A1AA&heavyWaste=false",
              "query": [
                {"key": "postcode", "value": "SW1A1AA"},
                {"key": "heavyWaste", "value": "false"}
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function() {",
                  "  pm.expect(pm.response.status).toBe(200);",
                  "});",
                  "pm.test(\"Returns 8 skips\", function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.skips.length).toBe(8);",
                  "});",
                  "pm.test(\"All skips enabled\", function() {",
                  "  const jsonData = pm.response.json();",
                  "  const disabled = jsonData.skips.filter(s => s.disabled);",
                  "  pm.expect(disabled.length).toBe(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get skips - Heavy waste (large disabled)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/skips?postcode=SW1A1AA&heavyWaste=true",
              "query": [
                {"key": "postcode", "value": "SW1A1AA"},
                {"key": "heavyWaste", "value": "true"}
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Large skips disabled\", function() {",
                  "  const jsonData = pm.response.json();",
                  "  const disabled8 = jsonData.skips.find(s => s.size === '8-yard' && s.disabled);",
                  "  pm.expect(disabled8).toBeTruthy();",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get skips - Plasterboard",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/skips?postcode=SW1A1AA&plasterboard=true",
              "query": [
                {"key": "postcode", "value": "SW1A1AA"},
                {"key": "plasterboard", "value": "true"}
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function() {",
                  "  pm.expect(pm.response.status).toBe(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Booking",
      "item": [
        {
          "name": "Confirm booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/booking/confirm",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postcode\": \"SW1A 1AA\",\n  \"addressId\": \"addr_1\",\n  \"heavyWaste\": true,\n  \"plasterboard\": false,\n  \"skipSize\": \"4-yard\",\n  \"price\": 150\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function() {",
                  "  pm.expect(pm.response.status).toBe(200);",
                  "});",
                  "pm.test(\"Returns booking ID\", function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.bookingId).toMatch(/^BK-/);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}