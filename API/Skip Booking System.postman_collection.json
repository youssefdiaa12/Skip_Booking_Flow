  "item": [
    {
      "name": "Postcode Lookup",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.test(\"Request body is sent\", function () {\r",
              "    pm.expect(pm.request.body).to.exist;\r",
              "    pm.expect(pm.request.body.raw).to.not.be.empty;\r",
              "});\r",
              "\r",
              "const body = JSON.parse(pm.request.body.raw);\r",
              "\r",
              "pm.test(\"Postcode exists in request body\", function () {\r",
              "    pm.expect(body).to.have.property(\"postcode\");\r",
              "});\r",
              "\r",
              "pm.test(\"Postcode is not empty\", function () {\r",
              "    pm.expect(body.postcode).to.be.a(\"string\").and.not.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();\r",
              "const postCodeVar = pm.variables.get(\"PostCode\");\r",
              "\r",
              "pm.test(\"Response status is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response postcode matches PostCode variable\", function () {\r",
              "    pm.expect(responseBody).to.have.property(\"postcode\");\r",
              "    pm.expect(responseBody.postcode).to.eql(postCodeVar);\r",
              "});\r",
              "\r",
              "pm.test(\"Addresses array exists and is not empty\", function () {\r",
              "    pm.expect(responseBody).to.have.property(\"addresses\");\r",
              "    if(pm.expect(responseBody.addresses).to.be.an(\"array\").that.is.not.empty){\r",
              "    const addressId = responseBody.addresses[0].id;\r",
              "        pm.environment.set(\"addressId\", addressId);\r",
              "    }\r",
              "\r",
              "});\r",
              "\r",
              "// saving address index 0 id to environment variable\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"postcode\": \"{{PostCode}}\",\r\n    \"retry\": false\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BaseURL}}/postcode/lookup",
          "host": [
            "{{BaseURL}}"
          ],
          "path": [
            "postcode",
            "lookup"
          ]
        }
      },
      "response": []
    },
