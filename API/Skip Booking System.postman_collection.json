    {
      "name": "Skip Selection",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();\r",
              "\r",
              "/**\r",
              " * 1️ Check response status\r",
              " */\r",
              "pm.test(\"Response status is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "/**\r",
              " * 2️ Verify plasterboard=true was sent\r",
              " */\r",
              "pm.test(\"Plasterboard query param is true\", function () {\r",
              "    const plasterboard = pm.request.url.query.get(\"plasterboard\");\r",
              "    pm.expect(plasterboard).to.eql(\"true\");\r",
              "});\r",
              "\r",
              "/**\r",
              " * 3️ Check skips array exists and is not empty\r",
              " */\r",
              "pm.test(\"Skips array exists and is not empty\", function () {\r",
              "    pm.expect(responseBody).to.have.property(\"skips\");\r",
              "    pm.expect(responseBody.skips).to.be.an(\"array\").that.is.not.empty;\r",
              "\r",
              "    \r",
              "// Get first skip\r",
              "const firstSkip = responseBody.skips[0];\r",
              "\r",
              "// Save values to environment variables\r",
              "pm.environment.set(\"SkipSize\", firstSkip.size);\r",
              "pm.environment.set(\"SkipPrice\", firstSkip.price);\r",
              "\r",
              "});\r",
              "\r",
              "/**\r",
              " * 4️ Validate disabled logic when plasterboard=true\r",
              " */\r",
              "pm.test(\"Disabled flag is correctly applied for plasterboard=true\", function () {\r",
              "    const disabledSizes = [\"14-yard\", \"16-yard\", \"20-yard\"];\r",
              "    const enabledSizes = [\"4-yard\", \"6-yard\", \"8-yard\", \"10-yard\", \"12-yard\"];\r",
              "\r",
              "    responseBody.skips.forEach(skip => {\r",
              "        if (disabledSizes.includes(skip.size)) {\r",
              "            pm.expect(\r",
              "                skip.disabled,\r",
              "                `${skip.size} should be disabled`\r",
              "            ).to.be.true;\r",
              "        }\r",
              "\r",
              "        if (enabledSizes.includes(skip.size)) {\r",
              "            pm.expect(\r",
              "                skip.disabled,\r",
              "                `${skip.size} should NOT be disabled`\r",
              "            ).to.be.false;\r",
              "        }\r",
              "    });\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BaseURL}}/skips?postcode={{PostCode}}&plasterboard=true",
          "host": [
            "{{BaseURL}}"
          ],
          "path": [
            "skips"
          ],
          "query": [
            {
              "key": "postcode",
              "value": "{{PostCode}}"
            },
            {
              "key": "plasterboard",
              "value": "true"
            }
          ]
        }
      },
      "response": []
    },
