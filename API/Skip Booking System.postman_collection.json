              " * 1️ Check response status\r",
              " */\r",
              "pm.test(\"Response status is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"check response body has property ok and it's value is true\", function () {\r",
              "    pm.expect(responseBody).to.have.property(\"ok\");\r",
              "    // check if ok is true as test\r",
              "    pm.expect(responseBody.ok).to.be.true;\r",
              "    \r",
              "});\r",
              ""
            ],
